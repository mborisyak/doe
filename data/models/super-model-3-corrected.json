{
  "states": ["A", "B"],
  "parameters": {
    "kcat": [10.0, 5000.0],
    "K_A": [0.01, 5.0],
    "K_B": [0.01, 5.0],
    "Ea": [1.0, 200.0],
    "kd_ref": [0.001, 10.0],
    "Ed": [50.0, 500.0],
    "delta_H":     [20000.0, 80000.0],
    "delta_C":     [100.0, 2000.0],
    "T_melting":   [40.0, 65.0]
  },
  "initial_state": {
    "A": "A0",
    "B": "B0"
  },
  "algebraics": {
    "T_K":      "T + 273.15",
    "Tm_K": "T_melting + 273.15",
    "kcat_T": "kcat * exp(-Ea / 0.008314 * (1.0 / (T + 273.15) - 1.0 / 323.15))",
    "dG": "delta_H * (1 - T_K / Tm_K) - delta_C * ((Tm_K - T_K) - T_K * log(Tm_K / T_K))",
    "f_active": "1 / (1 + exp(-dG / T_K))",
    "E_active": "f_active * E0",
    "rate": "E_active * kcat_T * A / (K_A + A) * B / (K_B + B)"
  },
  "rhs": {
    "A": "-rate",
    "B": "-rate"
  },
  "observables": {
    "A": "A"
  }
}