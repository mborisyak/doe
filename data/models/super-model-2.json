{
  "states": ["A"],
  "parameters": {
    "log_kcat0": [3.0, 8.0],
    "Q10_kcat": [1.1, 2.5],
    "log_Km_A0": [-3.0, 2.0],
    "Q10_Km_A": [1.05, 2.5],
    "log_Km_B0": [-3.0, 2.0],
    "Q10_Km_B": [1.05, 2.5],
    "log_Ki_C0": [-2.0, 3.0],
    "Q10_Ki_C": [1.05, 2.5],
    "dH": [50.0, 250.0],
    "Tm": [40.0, 65.0],
    "dCp": [0.0, 20.0]
  },
  "initial_state": {
    "A": "A0"
  },
  "algebraics": {
    "T_K": "T + 273.15",
    "Tm_K": "Tm + 273.15",
    "dG": "dH * (1 - T_K / Tm_K) - dCp * ((Tm_K - T_K) - T_K * log(Tm_K / T_K))",
    "f_active": "1 / (1 + exp(-dG / T_K))",
    "E_active": "f_active * E0",
    "kcat": "exp(log_kcat0 + log(Q10_kcat) * (1/273.15 - 1/(T + 273.15)) / (1/273.15 - 1/283.15))",
    "Km_A": "exp(log_Km_A0 + log(Q10_Km_A) * (1/273.15 - 1/(T + 273.15)) / (1/273.15 - 1/283.15))",
    "Km_B": "exp(log_Km_B0 + log(Q10_Km_B) * (1/273.15 - 1/(T + 273.15)) / (1/273.15 - 1/283.15))",
    "Ki_C": "exp(log_Ki_C0 + log(Q10_Ki_C) * (1/273.15 - 1/(T + 273.15)) / (1/273.15 - 1/283.15))",
    "delta": "A0 - A",
    "B": "B0 - delta",
    "C": "delta",
    "Km_A_app": "Km_A * (1 + C / Ki_C)",
    "rate": "E_active * kcat * A / (Km_A_app + A) * B / (Km_B + B)"
  },
  "rhs": {
    "A": "-rate"
  },
  "observables": {
    "A": "A"
  }
}